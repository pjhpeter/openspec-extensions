{
  "name": "openspec-extensions",
  "version": "1.1.3",
  "description": "OpenSpec issue-mode extensions packaged for npm-first distribution.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pjhpeter/openspec-extensions.git"
  },
  "homepage": "https://github.com/pjhpeter/openspec-extensions#readme",
  "bugs": {
    "url": "https://github.com/pjhpeter/openspec-extensions/issues"
  },
  "bin": {
    "openspec": "dist/cli/openspec.js",
    "openspec-ex": "dist/cli/index.js",
    "openspec-extensions": "dist/cli/index.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "skills",
    "templates",
    "README.md"
  ],
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "lint": "eslint . --ext .ts,.mts,.cts",
    "prepack": "npm run build",
    "smoke:package": "node scripts/package_smoke_test.js",
    "type-check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@fission-ai/openspec": "~1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^22.15.17",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.26.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
